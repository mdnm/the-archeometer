---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  keywords?: string[];
}

const {
  title,
  description = "The Archeometer - An English translation of Saint-Yves d'Alveydre's masterpiece on the key to all religions and sciences of antiquity.",
  image = "/og-image.png",
  type = "website",
  publishedTime,
  keywords = ["The Archeometer", "Saint-Yves d'Alveydre"],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    {/* Primary Meta Tags */}
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content={Array.isArray(keywords) ? keywords.join(", ") : keywords}
    />
    <meta name="generator" content={Astro.generator} />

    {/* Open Graph / Facebook */}
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:site_name" content="The Archeometer" />
    {
      publishedTime && type === "article" && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }

    {/* Twitter */}
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    {/* Additional SEO */}
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#1a1a2e" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Google Analytics -->
    <script
      is:inline
      type="text/partytown"
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-8HP23EQKQ3"></script>
    <script is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-8HP23EQKQ3");
    </script>

    <script is:inline>
      // On page load or when changing themes, best to add inline in `head` to avoid FOUC
      if (
        localStorage.getItem("color-theme") === "dark" ||
        (!("color-theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>

    {/* JSON-LD for better SEO */}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": type === "article" ? "Article" : "WebSite",
        url: canonicalURL,
        name: title,
        description: description,
        image: socialImageURL,
        ...(type === "article" && publishedTime
          ? {
              datePublished: publishedTime,
              author: {
                "@type": "Person",
                name: "Saint-Yves d'Alveydre",
              },
            }
          : {}),
        publisher: {
          "@type": "Organization",
          name: "Mat Moura",
          logo: {
            "@type": "ImageObject",
            url: new URL("/favicon.svg", Astro.site),
          },
        },
      })}
    />
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text)] min-h-screen">
    <header
      class="bg-[var(--color-surface)] border-b border-[var(--color-border)]"
    >
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 w-full">
          <div class="flex w-full">
            <div class="flex-shrink-0 flex items-center">
              <a
                href="/"
                class="text-xl font-serif font-bold text-[var(--color-text)] tracking-wide"
                >The Archeometer</a
              >
            </div>

            <div class="hidden w-full sm:ml-6 sm:flex gap-4">
              <a
                href="/"
                class={`inline-flex items-center px-1 pt-1 text-sm font-medium ${Astro.url.pathname === "/" ? "border-b-2 border-[var(--color-active)] text-[var(--color-text)]" : "text-[var(--color-text-muted)] hover:border-b-2 hover:border-[var(--color-border)]"}`}
              >
                E-Book
              </a>
              <a
                href="/natal-chart"
                class={`inline-flex items-center px-1 pt-1 text-sm font-medium ${Astro.url.pathname === "/natal-chart" ? "border-b-2 border-[var(--color-active)] text-[var(--color-text)]" : "text-[var(--color-text-muted)] hover:border-b-2 hover:border-[var(--color-border)]"}`}
              >
                Saint Yves Natal Chart
              </a>
              <a
                href="/archeometer"
                class={`inline-flex items-center px-1 pt-1 text-sm font-medium ${Astro.url.pathname === "/archeometer" ? "border-b-2 border-[var(--color-active)] text-[var(--color-text)]" : "text-[var(--color-text-muted)] hover:border-b-2 hover:border-[var(--color-border)]"}`}
              >
                The Archeometer
              </a>
            </div>
          </div>

          <ThemeToggle />

          {/* Mobile menu button */}
          <div class="sm:hidden flex items-center">
            <button
              type="button"
              class="mobile-menu-button inline-flex items-center justify-center p-2 rounded-md text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-alt)] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-arch-violet"
              aria-controls="mobile-menu"
              aria-expanded="false"
            >
              <span class="sr-only">Open main menu</span>
              <svg
                class="block h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </nav>

      {/* Mobile menu */}
      <div class="sm:hidden hidden" id="mobile-menu">
        <div class="pt-2 pb-3 space-y-1">
          <a
            href="/"
            class={`block pl-3 pr-4 py-2 text-base font-medium ${Astro.url.pathname === "/" ? "bg-[var(--color-surface-alt)] border-l-4 border-[var(--color-active)] text-[var(--color-text)]" : "text-[var(--color-text-muted)] hover:bg-[var(--color-surface-alt)]"}`}
          >
            E-Book
          </a>
          <a
            href="/natal-chart"
            class={`block pl-3 pr-4 py-2 text-base font-medium ${Astro.url.pathname === "/natal-chart" ? "bg-[var(--color-surface-alt)] border-l-4 border-[var(--color-active)] text-[var(--color-text)]" : "text-[var(--color-text-muted)] hover:bg-[var(--color-surface-alt)]"}`}
          >
            Saint Yves Natal Chart
          </a>
          <a
            href="/archeometer"
            class={`block pl-3 pr-4 py-2 text-base font-medium ${Astro.url.pathname === "/archeometer" ? "bg-[var(--color-surface-alt)] border-l-4 border-[var(--color-active)] text-[var(--color-text)]" : "text-[var(--color-text-muted)] hover:bg-[var(--color-surface-alt)]"}`}
          >
            The Archeometer
          </a>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto sm:px-6 lg:px-8">
      <slot />
    </main>

    <footer
      class="bg-[var(--color-surface)] border-t border-[var(--color-border)] mt-12"
    >
      <div
        class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8 text-center text-sm text-[var(--color-text-muted)] space-y-1"
      >
        <p>
          Translated by <a
            href="https://x.com/matmoura19"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-link)] hover:underline">@matmoura19</a
          > with the help of <a
            href="https://translateabook.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-link)] hover:underline"
            >translateabook.com</a
          >.
        </p>
        <p>&copy; {new Date().getFullYear()} All rights reserved.</p>
        <p>
          <a
            href="https://github.com/mdnm/the-archeometer"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-link)] hover:underline">Source code</a
          >
        </p>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const mobileMenuButton = document.querySelector(".mobile-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");

      mobileMenuButton?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
      });
    </script>
  </body>
</html>
