---
import NatalChartWheel from "../components/NatalChartWheel";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Saint Yves Natal Chart - The Archeometer">
  <div class="px-4 py-5 sm:p-6">
    <h1 class="text-2xl font-serif font-bold text-[var(--color-text)] mb-6">
      Saint Yves D'Alveydre's Natal Chart
    </h1>

    <div class="w-full mx-auto mb-8 flex flex-col gap-6">
      <NatalChartWheel client:only="react" />

      <p class="text-[var(--color-text-muted)] text-center text-sm">
        Live-rendered natal chart using <a
          href="https://docs.kaabalah.com"
          target="_blank"
          class="text-[var(--color-link)] hover:underline"
          >kaabalah</a
        >
      </p>
    </div>

    <div class="mt-6 text-[var(--color-text)]">
      <h2 class="text-xl font-bold">About the Chart</h2>
      <p>
        This is the natal chart of Saint Yves D'Alveydre, the creator of The
        Archeometer.
      </p>
      <p>Born on March 26, 1842, in Paris, France, at supposedly 01:00 AM.</p>
    </div>
  </div>
</Layout>
