---
import { generateArcheometerSvg } from 'kaabalah/visual';
import GematriaStrudelPlayer from '../components/GematriaStrudelPlayer';
import Layout from '../layouts/Layout.astro';

const archeometerSvg = generateArcheometerSvg({
  width: 912,
  height: 912,
  background: "transparent",
  title: "The Cosmological Archeometer",
});
---

<Layout title="The Archeometer">
  <div class="bg-white dark:bg-gray-800 shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">The Archeometer</h1>

      <p class="text-gray-900 dark:text-white">
        There are many practical applications of the Archeometer. The tools and screenshots below will give you some ideas.
      </p>

      <div class="mt-6 text-gray-900 dark:text-white">
        <h2 class="text-xl font-bold">The Visual Archeometer</h2>
        <div class="w-full max-w-2xl mx-auto my-4 [&>svg]:w-full [&>svg]:h-auto" set:html={archeometerSvg} />
        <p class="text-gray-500 dark:text-gray-400 mt-1 text-center">
          The Cosmological Archeometer — rendered using <a
            href="https://docs.kaabalah.com"
            target="_blank"
            class="text-indigo-600 dark:text-indigo-500 hover:text-indigo-800 dark:hover:text-indigo-700"
          >kaabalah</a>
        </p>
      </div>

      <div class="mt-6 text-gray-900 dark:text-white">
        <h2 class="text-xl font-bold">The Archeometer and Music</h2>
        <GematriaStrudelPlayer client:only="react" />
        <img src="/solar-alphabet.png" alt="The Archeometer and Music" class="w-full max-w-lg mx-auto h-auto rounded-md" />
        <p class="text-gray-500 dark:text-gray-400 mt-1 text-center">
          Each letter corresponds astrologically to a planet or sign, and those correspond to specific notes.
        </p>
      </div>
    </div>
  </div>
</Layout>
