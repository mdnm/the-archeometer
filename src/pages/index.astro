---
import { getCollection } from "astro:content";
import { generateArcheometerSvg } from "kaabalah/visual";
import Layout from "../layouts/Layout.astro";

const chapters = await getCollection("chapters");
const sorted = chapters.sort((a, b) => a.data.chapter - b.data.chapter);
const stripExt = (id: string) => id.replace(/\.mdx?$/, "");

const archeometerSvg = generateArcheometerSvg({
  width: 912,
  height: 912,
  background: "transparent",
  title: "The Cosmological Archeometer",
});
---

<Layout title="The Archeometer - English Translation">
  {/* Hero */}
  <section
    class="hero-gradient px-4 py-16 sm:py-24 flex flex-col sm:flex-row items-center gap-10 sm:gap-16"
  >
    <div class="flex-1 min-w-0">
      <h1
        class="font-serif text-5xl sm:text-6xl font-bold text-[var(--color-text)] leading-tight mb-4"
      >
        The Archeometer
      </h1>
      <p class="font-serif text-xl italic text-[var(--color-text-muted)] mb-6">
        Key to All Religions and All Sciences of Antiquity
      </p>
      <p
        class="text-[var(--color-text-muted)] leading-relaxed mb-4 max-w-prose"
      >
        An English translation of <i
          >L'Archéomètre &mdash; Clef de toutes les religions et de toutes les
          sciences de l'Antiquité</i
        > by Saint-Yves d'Alveydre.
      </p>
      <p
        class="text-[var(--color-text-muted)] leading-relaxed mb-8 max-w-prose"
      >
        The Archeometer is an instrument for measuring the principles underlying
        all religions and sciences of antiquity. Saint-Yves d'Alveydre spent
        decades reconstructing this ancient system of correspondences between
        letters, numbers, musical notes, colors, planets, and zodiacal signs.
        Revealing a universal Logos at the root of all sacred traditions.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a
          href="#chapters"
          class="px-6 py-3 bg-[var(--color-accent)] text-white rounded-lg font-medium hover:opacity-90 transition-opacity"
        >
          Read the Book
        </a>
        <a
          href="/archeometer"
          class="px-6 py-3 border border-[var(--color-border)] text-[var(--color-text)] rounded-lg font-medium hover:bg-[var(--color-surface-alt)] transition-colors"
        >
          Interactive Tool
        </a>
      </div>
    </div>

    <div
      class="flex-shrink-0 w-full sm:w-auto sm:max-w-sm [&>svg]:w-full [&>svg]:h-auto"
      set:html={archeometerSvg}
    />
  </section>

  {/* Chapters */}
  <section id="chapters" class="px-4 py-10">
    <h2 class="font-serif text-2xl font-bold text-[var(--color-text)] mb-6">
      Chapters
    </h2>
    <div class="space-y-2">
      {
        sorted.map(({ id, data }) => (
          <a
            href={`/chapters/${stripExt(id)}`}
            class="chapter-item flex bg-[var(--color-surface)] hover:bg-[var(--color-surface-alt)] p-4 rounded-r-lg transition-colors group"
          >
            <div>
              <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-active)]">
                Chapter {data.chapter}: {data.title}
              </span>
              <p class="text-sm text-[var(--color-text-muted)] mt-0.5">
                {data.part}
              </p>
            </div>
          </a>
        ))
      }
    </div>
    <p class="mt-4 text-sm italic text-[var(--color-text-muted)]">
      More chapters coming soon.
    </p>
  </section>

  {/* Interactive Tools */}
  <section class="px-4 py-8 pb-16">
    <h2 class="font-serif text-2xl font-bold text-[var(--color-text)] mb-6">
      Interactive Tools
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a
        href="/archeometer"
        class="card-mystical p-6 group hover:border-arch-ether transition-colors"
      >
        <div class="w-3 h-3 rounded-full bg-arch-ether mb-3"></div>
        <span class="font-serif font-semibold text-lg text-[var(--color-text)]"
          >The Archeometer</span
        >
        <p class="text-sm text-[var(--color-text-muted)] mt-1">
          Interactive SVG visual with gematria music player
        </p>
      </a>
      <a
        href="/natal-chart"
        class="card-mystical p-6 group hover:border-arch-violet transition-colors"
      >
        <div class="w-3 h-3 rounded-full bg-arch-violet mb-3"></div>
        <span class="font-serif font-semibold text-lg text-[var(--color-text)]"
          >Saint-Yves' Natal Chart</span
        >
        <p class="text-sm text-[var(--color-text-muted)] mt-1">
          Live-rendered astrological natal chart
        </p>
      </a>
    </div>
  </section>
</Layout>
